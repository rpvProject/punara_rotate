# Punara marketing site — all runtime configuration.
# Copy to .env.local and edit. All values have working defaults (see src/lib/config.ts).

# Booking link used by EVERY "Book a Strategy Call" CTA.
NEXT_PUBLIC_BOOKING_URL=https://cal.com/punara/strategy

# "Explore Platform" CTA target (Punara Lens).
NEXT_PUBLIC_PLATFORM_URL=http://127.0.0.1:3010

# Canonical base URL of this site (metadataBase, OG, sitemap).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3020

# Public contact-form key — get a free one at web3forms.com (it is tied to your
# inbox email, safe to expose). Empty = form shows the hello@punara.com fallback.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Static-export sub-path. Empty for a custom domain (site at /). Set to "/repo"
# only for a GitHub project-pages preview served under a sub-path.
NEXT_PUBLIC_BASE_PATH=

# Analytics IDs — leave empty to render NO tracking scripts and NO cookie banner.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_TAG_ID=
